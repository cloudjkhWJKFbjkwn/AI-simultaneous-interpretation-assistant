# 百度 AI 语音识别
# 注册地址: https://console.bce.baidu.com/ai/#/ai/speech/app/list
BAIDU_API_KEY=your_api_key_here
BAIDU_SECRET_KEY=your_secret_key_here

# 百度文本翻译 API (通用翻译)
# 注册地址: https://fanyi-api.baidu.com/api/trans/product/index
# 每月免费 50 万字符
BAIDU_APP_ID=your_app_id_here

# 翻译策略: mock（本地词典）| baidu（百度翻译 API）
VITE_TRANSLATION_STRATEGY=mock
